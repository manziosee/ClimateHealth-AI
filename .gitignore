# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/

# ML models — baked into Docker image at build time
# Keep .pkl files in repo so Fly.io remote build has them
# They are regenerated monthly via GitHub Actions train-models.yml
!app/ml/saved_models/*.pkl
!app/ml/saved_models/metrics.json

# Env — keep .env.example, ignore real .env
.env
!.env.example

# Data
app/data/raw/
app/data/processed/

# Docker
*.log

# IDE
.vscode/
.idea/

# Fly.io
.fly/
