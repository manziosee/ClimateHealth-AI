# App
APP_ENV=development
SECRET_KEY=change-me-in-production

# Neon PostgreSQL — asyncpg uses ssl=require NOT sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require

# Redis
REDIS_URL=redis://redis:6379/0

# External APIs
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1
WHO_BASE_URL=https://ghoapi.azureedge.net/api
WORLD_BANK_BASE_URL=https://api.worldbank.org/v2

# Cache TTL (seconds)
WEATHER_CACHE_TTL=1800
PREDICTION_CACHE_TTL=3600
DISEASE_CACHE_TTL=86400

# AI Services (optional — endpoints return 503 when not set)
# Groq Cloud — https://console.groq.com/keys
GROQ_API_KEY=
# Hugging Face Inference API — https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=
