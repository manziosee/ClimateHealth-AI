# Normalize line endings
* text=auto

# Force Unix LF for these file types
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.sh    text eol=lf
*.conf  text eol=lf
*.ini   text eol=lf
*.mako  text eol=lf
*.css   text eol=lf
*.mjs   text eol=lf

# Binary files — no line ending conversion
*.png  binary
*.jpg  binary
*.ico  binary
*.pkl  binary
*.h5   binary
